# ===========================================
# CORA - Variables de Entorno (Backend)
# ===========================================
# Copiar este archivo a .env y completar con tus credenciales reales
# NUNCA hacer commit del archivo .env con credenciales reales

# ===========================================
# APLICACIÓN
# ===========================================

# Entorno: development | staging | production
NODE_ENV=development

# Puerto del servidor (default: 3001)
PORT=3001

# URL del frontend (para CORS y emails)
FRONTEND_URL=http://localhost:5173

# ===========================================
# SUPABASE
# ===========================================
# Obtener de: https://supabase.com/dashboard > Settings > API

# URL del proyecto Supabase
# Formato: https://tu-proyecto-id.supabase.co
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (safe para frontend, pero la usamos solo en backend para验证)
# Obtener de: Settings > API > anon/public key
SUPABASE_ANON_KEY=tu-anon-key-aqui

# Clave de servicio (SOLO PARA BACKEND - NUNCA exponer al frontend)
# Obtener de: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Secreto JWT de Supabase (para verificar tokens)
# Obtener de: Settings > API > JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret-aqui

# ===========================================
# STRIPE (Pagos)
# ===========================================
# Obtener de: https://dashboard.stripe.com/apikeys

# Clave secreta de Stripe (modo test: sk_test_, producción: sk_live_)
STRIPE_SECRET_KEY=sk_test_tu-clave-secreta-aqui

# Webhook signing secret (obtener con: stripe listen --forward-to localhost:3001/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_tu-webhook-secret-aqui

# Price IDs de Stripe (crear productos en Dashboard > Products)
STRIPE_MONTHLY_PRICE_ID=price_tu-precio-mensual-aqui
STRIPE_ANNUAL_PRICE_ID=price_tu-precio-anual-aqui
STRIPE_PER_SESSION_PRICE_ID=price_tu-precio-por-sesion-aqui

# Porcentaje de comisión de plataforma (default: 15)
PLATFORM_COMMISSION_PERCENT=15

# ===========================================
# EMAIL (SendGrid)
# ===========================================
# Alternativas: Resend, Amazon SES, Mailgun

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false

# Usuario (generalmente 'apikey' para SendGrid)
SMTP_USER=apikey

# Contraseña/API Key de SendGrid
SMTP_PASS=tu-sendgrid-api-key-aqui

# Email remitente (debe estar verificado en SendGrid)
EMAIL_FROM=noreply@tucora.com
EMAIL_FROM_NAME=Cora Platform

# ===========================================
# RATE LIMITING
# ===========================================

# Ventana de tiempo para rate limit (en milisegundos)
# Default: 15 minutos
RATE_LIMIT_WINDOW_MS=900000

# Máximo de requests por ventana
# Default: 100 requests
RATE_LIMIT_MAX=100

# Rate limit estricto para auth (intentos de login)
# Default: 5 intentos por hora
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=3600000

# ===========================================
# LOGGING
# ===========================================

# Nivel de log: error | warn | info | debug
LOG_LEVEL=info

# Formato de log: simple | json
LOG_FORMAT=simple

# ===========================================
# SESSION / COOKIES
# ===========================================

# Secreto para signed cookies (mínimo 32 caracteres)
COOKIE_SECRET=tu-cookie-secret-minimo-32-caracteres-aqui

# Duración de sesión en ms (7 días)
SESSION_DURATION_MS=604800000

# ===========================================
# WEBRTC / VIDEO
# ===========================================

# STUN/TURN servers para WebRTC
# Usar servicios públicos o configurar los tuyos
STUN_SERVER_1=stun:stun.l.google.com:19302
STUN_SERVER_2=stun:stun1.l.google.com:19302

# TURN server (paraNAT traversal) - opcional pero recomendado
# TURN_SERVER=turn:tu-turn-server.com:3478
# TURN_USERNAME=tu-username
# TURN_CREDENTIAL=tu-credential

# Máximo de participantes en sala de video
MAX_VIDEO_PARTICIPANTS=2

# Duración máxima de sesión en segundos (50 min + 10 min buffer)
MAX_SESSION_DURATION_SECONDS=3600

# ===========================================
# SEGURIDAD
# ===========================================

# Longitud mínima de contraseña
PASSWORD_MIN_LENGTH=8

# Requerimientos de contraseña
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Máximo de intentos de login antes de bloqueo
MAX_LOGIN_ATTEMPTS=5

# Duración de bloqueo en ms (1 hora)
LOCKOUT_DURATION_MS=3600000

# ===========================================
# STORAGE (Supabase Storage)
# ===========================================

# Buckets de storage
STORAGE_AVATARS_BUCKET=avatars
STORAGE_DOCUMENTS_BUCKET=documents
STORAGE_RECORDINGS_BUCKET=recordings

# Tamaño máximo de archivos (en bytes)
# Default: 50MB
MAX_FILE_SIZE_BYTES=52428800

# Tipos MIME permitidos para avatars
ALLOWED_AVATAR_TYPES=image/jpeg,image/png,image/webp

# ===========================================
# CORS
# ===========================================

# Orígenes permitidos (separados por coma)
# Para desarrollo local:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Para producción, agregar:
# ALLOWED_ORIGINS=https://tucora.com,https://www.tucora.com

# ===========================================
# DATABASE (opcional, si usas migraciones directas)
# ===========================================

# Connection string de PostgreSQL (si no usas Supabase)
# DATABASE_URL=postgresql://user:password@host:5432/cora

# ===========================================
# REDIS (opcional, para cache o queues)
# ===========================================

# Si necesitas Redis para cache/sessions:
# REDIS_URL=redis://localhost:6379

# ===========================================
# MONITORING (opcional)
# ===========================================

# Para integración con Sentry:
# SENTRY_DSN=https://tu-dsn@sentry.io/tu-proyecto

# Para integración con Datadog:
# DATADOG_API_KEY=tu-datadog-api-key

# ===========================================
# WEBHOOKS EXTERNOS
# ===========================================

# Webhook para notifications (Slack, Discord, etc.):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXX/BXXXXX/XXXXXXXXXX
